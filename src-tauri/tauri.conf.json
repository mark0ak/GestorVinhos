{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gestorvinhos",
  "version": "0.1.0",
  "identifier": "com.solardmanuel.gestorvinhos",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Solar D Manuel I - Gestor de Vinhos",
        "width": 1024,
        "height": 768,
        "visible": false
      },
      {
        "label": "splashscreen",
        "title": "Carregando...",
        "url": "splash.html",
        "width": 400,
        "height": 300,
        "decorations": false,
        "center": true,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
